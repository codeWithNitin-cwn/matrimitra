generator client {
  provider = "prisma-client"
  output   = "../../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  OWNER
  MANAGER
  EXECUTIVE
  VIEWER
}

enum ProfileStatus {
  DRAFT
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum DocumentType {
  ID_PROOF
  BIODATA
  EDUCATION
  INCOME
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Agency {
  id             String       @id @default(uuid())
  agencyCode     String       @unique
  name           String
  registrationNo String?
  email          String       @unique
  mobile         String
  website        String?
  city           String
  state          String
  country        String
  status         AgencyStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users              AgencyUser[]
  profiles           AgencyProfile[]

  sentProposals      Proposal[] @relation("SenderAgency")
  receivedProposals  Proposal[] @relation("ReceiverAgency")

  partnerships       AgencyPartnership[] @relation("AgencyPartnerships")
  partnerOf          AgencyPartnership[] @relation("PartnerAgencies")

  profileAccessLogs  ProfileAccessLog[]


}

model AgencyUser {
  id               String       @id @default(uuid())
  agencyId         String

  firstName        String
  lastName         String?

  email            String       @unique
  mobile           String

  username         String       @unique
  passwordHash     String

  role             UserRole
  status           AgencyStatus @default(ACTIVE)

  lastLogin        DateTime?
  createdAt        DateTime     @default(now())

  agency           Agency @relation(fields: [agencyId], references: [id])

  assignedProfiles  AgencyProfile[]

  followUps         FollowUp[]
  profileAccessLogs ProfileAccessLog[]
}

model Person {
  id          String    @id @default(uuid())

  firstName   String
  lastName    String?

  gender      String
  dob         DateTime?

  mobile      String?
  email       String?

  createdAt   DateTime  @default(now())

  profiles    AgencyProfile[]
}

model AgencyProfile {
  id                String        @id @default(uuid())

  agencyId          String
  personId          String
  assignedUserId    String?

  profileNumber     String        @unique
  profileType       String

  status            ProfileStatus @default(DRAFT)

  trustScore        Decimal?      @db.Decimal(5,2)
  completionPercent Int           @default(0)

  onboardingLink    String?
  onboardingExpiry  DateTime?
  aiSummary         String?       @db.Text

  createdAt         DateTime      @default(now())

  agency            Agency @relation(fields: [agencyId], references: [id])
  person            Person @relation(fields: [personId], references: [id])

  assignedUser      AgencyUser? @relation(fields: [assignedUserId], references: [id])

  personal          ProfilePersonal?

  educations        ProfileEducation[]
  careers           ProfileCareer[]
  families          ProfileFamily[]
  lifestyles        ProfileLifestyle[]
  preferences       ProfilePreference[]
  photos            ProfilePhoto[]
  documents         ProfileDocument[]

brideProposals         Proposal[] @relation("BrideProfile")
groomProposals         Proposal[] @relation("GroomProfile")

aiBrideCompatibilities AICompatibility[] @relation("BrideCompatibility")
aiGroomCompatibilities AICompatibility[] @relation("GroomCompatibility")

profileAccessLogs      ProfileAccessLog[]
}

model ProfilePersonal {
  id             String @id @default(uuid())

  profileId      String @unique

  religion       String?
  caste          String?
  subCaste       String?
  motherTongue   String?

  heightCm       Int?
  weightKg       Int?

  maritalStatus  String?

  city           String?
  state          String?
  country        String?

  profile        AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileEducation {
  id               String @id @default(uuid())

  profileId        String

  qualification    String
  specialization   String?
  institution      String?
  graduationYear   Int?

  profile          AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileCareer {
  id             String @id @default(uuid())

  profileId      String

  profession     String?
  employer       String?
  designation    String?

  annualIncome   Decimal? @db.Decimal(15,2)

  workLocation   String?

  profile        AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileFamily {
  id                String @id @default(uuid())

  profileId         String

  fatherName        String?
  motherName        String?

  fatherOccupation  String?
  motherOccupation  String?

  familyType        String?
  familyValues      String?

  siblingsCount     Int?

  profile           AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileLifestyle {
  id            String @id @default(uuid())

  profileId     String

  foodHabit     String?
  smoking       Boolean?
  drinking      Boolean?

  fitnessLevel  String?
  hobbies       Json?

  profile       AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfilePreference {
  id            String @id @default(uuid())

  profileId     String

  minAge        Int?
  maxAge        Int?

  minHeight     Int?
  maxHeight     Int?

  religion      String?
  caste         String?
  city          String?

  education     String?
  profession    String?

  profile       AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfilePhoto {
  id               String @id @default(uuid())

  profileId        String

  cloudinaryUrl    String
  thumbnailUrl     String?

  isPrimary        Boolean @default(false)

  approvalStatus   ApprovalStatus @default(PENDING)

  uploadedAt       DateTime @default(now())

  profile          AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileDocument {
  id               String @id @default(uuid())

  profileId        String

  documentType     DocumentType

  fileUrl          String

  approvalStatus   ApprovalStatus @default(PENDING)

  uploadedAt       DateTime @default(now())

  profile          AgencyProfile @relation(fields: [profileId], references: [id])
}

model AICompatibility {
  id              String   @id @default(uuid())
  brideProfileId  String
  groomProfileId  String
  score           Int
  explanation     String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brideProfile    AgencyProfile @relation("BrideCompatibility", fields: [brideProfileId], references: [id])
  groomProfile    AgencyProfile @relation("GroomCompatibility", fields: [groomProfileId], references: [id])

  @@unique([brideProfileId, groomProfileId])
  @@index([score])
}

model Proposal {
  id                String @id @default(uuid())

  proposalNumber    String @unique

  senderAgencyId    String
  receiverAgencyId  String

  brideProfileId    String
  groomProfileId    String

  proposalStatus    String
  proposalNotes     String?

  createdBy         String

  createdAt         DateTime @default(now())

  senderAgency      Agency @relation("SenderAgency", fields: [senderAgencyId], references: [id])
  receiverAgency    Agency @relation("ReceiverAgency", fields: [receiverAgencyId], references: [id])

  brideProfile      AgencyProfile @relation("BrideProfile", fields: [brideProfileId], references: [id])
  groomProfile      AgencyProfile @relation("GroomProfile", fields: [groomProfileId], references: [id])

  activities        ProposalActivity[]
  pipeline          Pipeline?
  conversation      Conversation?

  followUps         FollowUp[]
}

model ProposalActivity {
  id             String @id @default(uuid())

  proposalId     String

  activityType   String
  activityNotes  String?

  performedBy    String

  createdAt      DateTime @default(now())

  proposal       Proposal @relation(fields: [proposalId], references: [id])
}

model Pipeline {
  id            String @id @default(uuid())

  proposalId    String @unique

  currentStage  String

  stageDate     DateTime @default(now())

  updatedBy     String

  proposal      Proposal @relation(fields: [proposalId], references: [id])
}
model Conversation {
  id         String   @id @default(uuid())
  proposalId String   @unique
  createdAt  DateTime @default(now())

  proposal   Proposal @relation(fields: [proposalId], references: [id])

  messages   Message[]
}
model Message {
  id             String   @id @default(uuid())
  conversationId String

  senderUserId   String

  messageText    String
  attachmentUrl  String?

  sentAt         DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
}
model AuditLog {
  id          String   @id @default(uuid())

  agencyId    String
  userId      String

  entityType  String
  entityId    String

  action      String
  ipAddress   String?

  createdAt   DateTime @default(now())
}
model Notification {
  id               String   @id @default(uuid())

  userId           String

  title            String
  message          String

  notificationType String

  readFlag         Boolean  @default(false)

  createdAt        DateTime @default(now())
}
model AgencyPartnership {
  id              String   @id @default(uuid())

  agencyId        String
  partnerAgencyId String

  trustLevel      Int
  status          String

  createdAt       DateTime @default(now())

  agency          Agency @relation("AgencyPartnerships", fields: [agencyId], references: [id])
  partnerAgency   Agency @relation("PartnerAgencies", fields: [partnerAgencyId], references: [id])

  @@unique([agencyId, partnerAgencyId])
}

model ProfileAccessLog {
  id              String   @id @default(uuid())

  profileId       String
  viewedByUserId  String
  agencyId        String

  viewedAt        DateTime @default(now())

  durationSeconds Int?

  profile         AgencyProfile @relation(fields: [profileId], references: [id])
  viewedByUser    AgencyUser @relation(fields: [viewedByUserId], references: [id])
  agency          Agency @relation(fields: [agencyId], references: [id])
}

model FollowUp {
  id             String   @id @default(uuid())

  proposalId     String
  assignedUserId String

  dueDate        DateTime

  remarks        String?

  status         String

  proposal       Proposal @relation(fields: [proposalId], references: [id])
  assignedUser   AgencyUser @relation(fields: [assignedUserId], references: [id])
}