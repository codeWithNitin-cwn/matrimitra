generator client {
  provider = "prisma-client"
  output   = "../../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agency {
  id                String              @id @default(uuid())
  name              String
  email             String              @unique
  mobile            String
  city              String
  state             String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  agencyCode        String              @unique
  country           String
  registrationNo    String?
  website           String?
  status            AgencyStatus        @default(ACTIVE)
  partnerships      AgencyPartnership[] @relation("AgencyPartnerships")
  partnerOf         AgencyPartnership[] @relation("PartnerAgencies")
  profiles          AgencyProfile[]
  users             AgencyUser[]
  profileAccessLogs ProfileAccessLog[]
  receivedProposals Proposal[]          @relation("ReceiverAgency")
  sentProposals     Proposal[]          @relation("SenderAgency")
  clients           Client[]
  payments          Payment[]
}

model AgencyUser {
  id                String             @id @default(uuid())
  agencyId          String
  username          String             @unique
  email             String             @unique
  passwordHash      String
  createdAt         DateTime           @default(now())
  firstName         String
  lastLogin         DateTime?
  lastName          String?
  mobile            String
  role              UserRole
  status            AgencyStatus       @default(ACTIVE)
  assignedProfiles  AgencyProfile[]
  agency            Agency             @relation(fields: [agencyId], references: [id])
  followUps         FollowUp[]
  profileAccessLogs ProfileAccessLog[]
  clients           Client[]
  clientNotes       ClientNote[]
}

model Person {
  id        String          @id @default(uuid())
  firstName String
  lastName  String?
  gender    String
  mobile    String?
  email     String?
  createdAt DateTime        @default(now())
  dob       DateTime?
  profiles  AgencyProfile[]
}

model AgencyProfile {
  id                     String              @id @default(uuid())
  agencyId               String
  personId               String
  clientId               String?
  createdAt              DateTime            @default(now())
  assignedUserId         String?
  completionPercent      Int                 @default(0)
  onboardingExpiry       DateTime?
  onboardingLink         String?
  onboardingToken        String?             @unique
  clientApproved         Boolean             @default(false)
  clientApprovedAt       DateTime?
  agencyApproved         Boolean             @default(false)
  agencyApprovedAt       DateTime?
  clientRejectedReason   String?
  profileNumber          String              @unique
  profileType            String
  relationshipToClient   String?
  trustScore             Decimal?            @db.Decimal(5, 2)
  status                 ProfileStatus       @default(DRAFT)
  aiSummary              String?
  aiBrideCompatibilities AICompatibility[]   @relation("BrideCompatibility")
  aiGroomCompatibilities AICompatibility[]   @relation("GroomCompatibility")
  agency                 Agency              @relation(fields: [agencyId], references: [id])
  assignedUser           AgencyUser?         @relation(fields: [assignedUserId], references: [id])
  person                 Person              @relation(fields: [personId], references: [id])
  client                 Client?             @relation(fields: [clientId], references: [id])
  profileAccessLogs      ProfileAccessLog[]
  answers                ProfileAnswer[]
  careers                ProfileCareer[]
  documents              ProfileDocument[]
  educations             ProfileEducation[]
  families               ProfileFamily[]
  lifestyles             ProfileLifestyle[]
  personal               ProfilePersonal?
  photos                 ProfilePhoto[]
  preferences            ProfilePreference[]
  brideProposals         Proposal[]          @relation("BrideProfile")
  groomProposals         Proposal[]          @relation("GroomProfile")
  compatibilitiesSent     CompatibilityResult[] @relation("SourceCompatibility")
  compatibilitiesReceived CompatibilityResult[] @relation("TargetCompatibility")
  traits                  UserTrait?
  followUps               FollowUp[]
}

model ProfilePersonal {
  id            String        @id @default(uuid())
  profileId     String        @unique
  religion      String?
  caste         String?
  subCaste      String?
  motherTongue  String?
  heightCm      Int?
  weightKg      Int?
  maritalStatus String?
  city          String?
  state         String?
  country       String?
  profile       AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileEducation {
  id             String        @id @default(uuid())
  profileId      String
  qualification  String
  specialization String?
  institution    String?
  graduationYear Int?
  profile        AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileCareer {
  id           String        @id @default(uuid())
  profileId    String
  profession   String?
  employer     String?
  designation  String?
  annualIncome Decimal?      @db.Decimal(15, 2)
  workLocation String?
  profile      AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileFamily {
  id               String        @id @default(uuid())
  profileId        String
  fatherName       String?
  motherName       String?
  fatherOccupation String?
  motherOccupation String?
  familyType       String?
  familyValues     String?
  siblingsCount    Int?
  profile          AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfileLifestyle {
  id           String        @id @default(uuid())
  profileId    String
  foodHabit    String?
  smoking      Boolean?
  drinking     Boolean?
  fitnessLevel String?
  hobbies      Json?
  profile      AgencyProfile @relation(fields: [profileId], references: [id])
}

model ProfilePreference {
  id                      String             @id @default(uuid())
  profileId               String
  minAge                  Int?
  maxAge                  Int?
  minHeight               Int?
  maxHeight               Int?
  religion                String?
  caste                   String?
  city                    String?
  education               String?
  profession              String?
  smokingPreference       Boolean?
  drinkingPreference      Boolean?
  childrenPreference      String?
  familySetupPreference   String?
  relocationPreference    String?
  agePriority             PreferencePriority @default(DOESNT_MATTER)
  castePriority           PreferencePriority @default(DOESNT_MATTER)
  cityPriority            PreferencePriority @default(DOESNT_MATTER)
  educationPriority       PreferencePriority @default(DOESNT_MATTER)
  heightPriority          PreferencePriority @default(DOESNT_MATTER)
  professionPriority      PreferencePriority @default(DOESNT_MATTER)
  religionPriority        PreferencePriority @default(DOESNT_MATTER)
  smokingPriority         PreferencePriority @default(DOESNT_MATTER)
  drinkingPriority        PreferencePriority @default(DOESNT_MATTER)
  childrenPriority        PreferencePriority @default(DOESNT_MATTER)
  familySetupPriority     PreferencePriority @default(DOESNT_MATTER)
  relocationPriority      PreferencePriority @default(DOESNT_MATTER)
  profile                 AgencyProfile      @relation(fields: [profileId], references: [id])
}

model ProfilePhoto {
  id             String         @id @default(uuid())
  profileId      String
  cloudinaryUrl  String
  thumbnailUrl   String?
  isPrimary      Boolean        @default(false)
  uploadedAt     DateTime       @default(now())
  approvalStatus ApprovalStatus @default(PENDING)
  profile        AgencyProfile  @relation(fields: [profileId], references: [id])
}

model ProfileDocument {
  id             String         @id @default(uuid())
  profileId      String
  fileUrl        String
  uploadedAt     DateTime       @default(now())
  documentType   DocumentType
  approvalStatus ApprovalStatus @default(PENDING)
  profile        AgencyProfile  @relation(fields: [profileId], references: [id])
}

model AICompatibility {
  id             String        @id @default(uuid())
  brideProfileId String
  groomProfileId String
  score          Int
  explanation    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  brideProfile   AgencyProfile @relation("BrideCompatibility", fields: [brideProfileId], references: [id])
  groomProfile   AgencyProfile @relation("GroomCompatibility", fields: [groomProfileId], references: [id])

  @@unique([brideProfileId, groomProfileId])
  @@index([score])
}

model Proposal {
  id               String             @id @default(uuid())
  proposalNumber   String             @unique
  senderAgencyId   String
  receiverAgencyId String
  brideProfileId   String
  groomProfileId   String
  proposalStatus   String
  proposalNotes    String?
  createdBy        String
  createdAt        DateTime           @default(now())
  conversation     Conversation?
  followUps        FollowUp[]
  pipeline         Pipeline?
  brideProfile     AgencyProfile      @relation("BrideProfile", fields: [brideProfileId], references: [id])
  groomProfile     AgencyProfile      @relation("GroomProfile", fields: [groomProfileId], references: [id])
  receiverAgency   Agency             @relation("ReceiverAgency", fields: [receiverAgencyId], references: [id])
  senderAgency     Agency             @relation("SenderAgency", fields: [senderAgencyId], references: [id])
  activities       ProposalActivity[]
}

model ProposalActivity {
  id            String   @id @default(uuid())
  proposalId    String
  activityType  String
  activityNotes String?
  performedBy   String
  createdAt     DateTime @default(now())
  proposal      Proposal @relation(fields: [proposalId], references: [id])
}

model Pipeline {
  id           String            @id @default(uuid())
  proposalId   String            @unique
  currentStage String
  stageDate    DateTime          @default(now())
  updatedBy    String
  proposal     Proposal          @relation(fields: [proposalId], references: [id])
  history      PipelineHistory[]
}

model PipelineHistory {
  id         String   @id @default(uuid())
  pipelineId String
  oldStage   String
  newStage   String
  changedBy  String
  changedAt  DateTime @default(now())
  notes      String?
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

model Conversation {
  id         String    @id @default(uuid())
  proposalId String    @unique
  createdAt  DateTime  @default(now())
  proposal   Proposal  @relation(fields: [proposalId], references: [id])
  messages   Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderUserId   String
  messageText    String
  attachmentUrl  String?
  sentAt         DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  agencyId   String
  userId     String
  entityType String
  entityId   String
  action     String
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id               String   @id @default(uuid())
  userId           String
  title            String
  message          String
  notificationType String
  readFlag         Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model Question {
  id           String           @id @default(uuid())
  questionText String
  category     QuestionCategory
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  answers      ProfileAnswer[]
  options      QuestionOption[]
}

model QuestionOption {
  id         String          @id @default(uuid())
  questionId String
  optionText String
  answers    ProfileAnswer[]
  question   Question        @relation(fields: [questionId], references: [id])
}

model ProfileAnswer {
  id               String           @id @default(uuid())
  profileId        String
  questionId       String
  selectedOptionId String
  importance       AnswerImportance
  createdAt        DateTime         @default(now())
  profile          AgencyProfile    @relation(fields: [profileId], references: [id])
  question         Question         @relation(fields: [questionId], references: [id])
  selectedOption   QuestionOption   @relation(fields: [selectedOptionId], references: [id])

  @@unique([profileId, questionId])
}

model AgencyPartnership {
  id              String   @id @default(uuid())
  agencyId        String
  partnerAgencyId String
  trustLevel      Int
  status          String
  createdAt       DateTime @default(now())
  agency          Agency   @relation("AgencyPartnerships", fields: [agencyId], references: [id])
  partnerAgency   Agency   @relation("PartnerAgencies", fields: [partnerAgencyId], references: [id])

  @@unique([agencyId, partnerAgencyId])
}

model ProfileAccessLog {
  id              String        @id @default(uuid())
  profileId       String
  viewedByUserId  String
  agencyId        String
  action          String        @default("VIEW_PROFILE")
  viewedAt        DateTime      @default(now())
  durationSeconds Int?
  agency          Agency        @relation(fields: [agencyId], references: [id])
  profile         AgencyProfile @relation(fields: [profileId], references: [id])
  viewedByUser    AgencyUser    @relation(fields: [viewedByUserId], references: [id])
}

model FollowUp {
  id             String         @id @default(uuid())
  profileId      String
  proposalId     String?
  assignedUserId String
  dueDate        DateTime
  priority       String         @default("MEDIUM")
  status         String         @default("PENDING")
  notes          String?
  createdAt      DateTime       @default(now())
  assignedUser   AgencyUser     @relation(fields: [assignedUserId], references: [id])
  proposal       Proposal?      @relation(fields: [proposalId], references: [id])
  profile        AgencyProfile  @relation(fields: [profileId], references: [id])
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  OWNER
  PROFILE_MANAGER
  MATCHING_MANAGER
  RELATIONSHIP_MANAGER
}

enum ProfileStatus {
  DRAFT
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
  AGENCY_COMPLETED
  ONBOARDING_SENT
  CLIENT_APPROVED
  AGENCY_APPROVED
  ACTIVE
}

enum DocumentType {
  ID_PROOF
  BIODATA
  EDUCATION
  INCOME
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionCategory {
  PERSONALITY
  RELATIONSHIP
  LIFESTYLE
  FAMILY_VALUES
  FUN
}

enum AnswerImportance {
  MUST_HAVE
  NICE_TO_HAVE
  DOESNT_MATTER
}

enum PreferencePriority {
  MUST_HAVE
  IMPORTANT
  PREFERRED
  DOESNT_MATTER
}

model Client {
  id                String          @id @default(uuid())
  agencyId          String
  clientCode        String          @unique
  firstName         String
  lastName          String?
  email             String?
  mobile            String
  address           String?
  status            ClientStatus    @default(LEAD)
  leadSource        String?
  assignedUserId    String?
  nextFollowUpAt    DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  agency            Agency          @relation(fields: [agencyId], references: [id])
  assignedUser      AgencyUser?     @relation(fields: [assignedUserId], references: [id])
  profiles          AgencyProfile[]
  notes             ClientNote[]
  payments          Payment[]
}

model ClientNote {
  id        String     @id @default(uuid())
  clientId  String
  authorId  String
  content   String
  createdAt DateTime   @default(now())
  client    Client     @relation(fields: [clientId], references: [id])
  author    AgencyUser @relation(fields: [authorId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  clientId      String
  agencyId      String
  amount        Decimal       @db.Decimal(15, 2)
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  transactionId String?
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        Client        @relation(fields: [clientId], references: [id])
  agency        Agency        @relation(fields: [agencyId], references: [id])
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model CompatibilityResult {
  id                     String        @id @default(uuid())
  sourceProfileId        String
  targetProfileId        String
  compatibilityScore     Int
  filterScore            Int
  questionnaireScore     Int
  lifestyleScore         Int
  educationCareerScore   Int?
  strengths              Json
  concerns               Json
  aiExplanation          String?
  confidenceScore        Int           @default(100)
  generatedAt            DateTime      @default(now())

  sourceProfile          AgencyProfile @relation("SourceCompatibility", fields: [sourceProfileId], references: [id])
  targetProfile          AgencyProfile @relation("TargetCompatibility", fields: [targetProfileId], references: [id])

  @@unique([sourceProfileId, targetProfileId])
  @@index([compatibilityScore])
}

model UserTrait {
  profileId          String        @id
  communicationScore Int?
  familyScore        Int?
  careerScore        Int?
  financialScore     Int?
  lifestyleScore     Int?
  emotionalScore     Int?
  traditionalScore   Int?
  parentingScore     Int?
  independenceScore  Int?
  generatedAt        DateTime      @default(now())

  profile            AgencyProfile @relation(fields: [profileId], references: [id])
}
