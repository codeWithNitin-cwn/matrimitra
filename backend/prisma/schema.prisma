generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agency {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  email       String       @unique
  mobile      String
  city        String?
  state       String?
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       AgencyUser[]
  profiles    AgencyProfile[]
}

model AgencyUser {
  id          String    @id @default(uuid())
  agencyId    String
  username    String    @unique
  email       String    @unique
  passwordHash String
  role        String
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())

  agency       Agency   @relation(fields: [agencyId], references: [id])
}

model Person {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String?
  gender      String
  mobile      String?
  email       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profiles    AgencyProfile[]
}

model AgencyProfile {
  id          String    @id @default(uuid())
  agencyId    String
  personId    String
  profileCode String    @unique
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agency      Agency    @relation(fields: [agencyId], references: [id])
  person      Person    @relation(fields: [personId], references: [id])
}